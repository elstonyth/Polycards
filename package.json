{
  "name": "pixelslot-game",
  "version": "0.3.1",
  "private": true,
  "description": "PixelSlot — a web-based game built with Next.js, React, and Tailwind CSS.",
  "author": "elstonyth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elstonyth/PixelSlot.git"
  },
  "homepage": "https://github.com/elstonyth/PixelSlot#readme",
  "bugs": {
    "url": "https://github.com/elstonyth/PixelSlot/issues"
  },
  "keywords": [
    "game",
    "pokenic",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "format": "prettier --write src scripts",
    "format:check": "prettier --check src scripts",
    "test": "vitest run",
    "sim:test": "node --test scripts/sim/**/*.test.mjs",
    "qa:csp": "node scripts/qa-csp.mjs",
    "test:a11y": "node scripts/qa-a11y.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@medusajs/js-sdk": "^2.17.2",
    "@medusajs/types": "^2.15.5",
    "@sentry/nextjs": "^10.63.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.9.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.10"
  }
}
