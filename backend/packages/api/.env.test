# Integration-test environment (loaded by jest.config.js via loadEnv("test")).
# @medusajs/test-utils creates a throwaway database per suite using these
# DB_* credentials — they must match the local pokenic-postgres container
# (the same medusa:medusa creds as DATABASE_URL in .env). Local dev/test
# only; never reuse these values outside docker-compose.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=medusa
DB_PASSWORD=medusa

# The auth limiter keys on the request IP, and in this harness EVERY suite's
# register/login calls share 127.0.0.1 (plus Redis state persists across the
# per-test DB resets) — production defaults would 429 unrelated suites. Kept
# effectively unlimited here; the dedicated auth-rate-limit suite overrides
# these with tight values via the runner's `env:` option.
# NOTE: that suite's shared-Redis assumptions also depend on the jest scripts
# keeping --runInBand — parallelizing the integration runs would make the
# shared rl:auth:ip:* keyspace cross-suite flaky.
AUTH_RATE_BURST_LIMIT=10000
AUTH_RATE_BURST_WINDOW_MS=10000
AUTH_RATE_LIMIT=10000
AUTH_RATE_WINDOW_MS=60000

# Same reasoning for the vault/credits read limiter.
STORE_READ_RATE_BURST_LIMIT=10000
STORE_READ_RATE_BURST_WINDOW_MS=10000
STORE_READ_RATE_LIMIT=10000
STORE_READ_RATE_WINDOW_MS=60000
