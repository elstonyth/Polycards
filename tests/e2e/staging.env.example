# Staging target for the FULL (mutating) E2E suite.
# Copy to tests/e2e/.env.e2e (gitignored) and edit, then:
#   pwsh scripts/run-e2e.ps1 -EnvFile tests/e2e/.env.e2e
#
# ⚠ Point ONLY at a NON-PROD, seeded backend. The suite creates/deletes packs,
#   rewrites odds, adjusts credits, and opens packs — it WILL mutate this target.
#   run-e2e.ps1 refuses to run if PW_BACKEND looks like the prod host.

# Storefront (production standalone build of the staging branch)
PW_BASE=http://localhost:4000
# Admin dashboard (vite, or the backend's /dashboard mount)
PW_ADMIN=http://localhost:7000/dashboard
# Backend Medusa
PW_BACKEND=http://localhost:9000
# Storefront publishable key for THIS backend (pk_…)
PW_PK=pk_a23d4482ee6673a760097f3d013aab59679ceaebab54f987638cbeeb0132863c
# Operator login on THIS backend
PW_ADMIN_EMAIL=qa-admin@pokenic.local
PW_ADMIN_PASSWORD=QaAdmin2026!

# ───────────────────────────────────────────────────────────────────────────
# Throwaway-DB staging recipe (isolate from your dev DB so a run can't dirty it)
#
# 1. Make an isolated DB on the existing Postgres container:
#      docker exec -it pokenic-postgres createdb -U postgres pokenic_staging
#
# 2. Run a SECOND backend on a free port against it (from backend/packages/api),
#    with DATABASE_URL pointed at pokenic_staging, then migrate + seed:
#      $env:DATABASE_URL="postgres://postgres:postgres@localhost:5432/pokenic_staging"
#      $env:PORT="9100"
#      corepack yarn medusa db:migrate
#      corepack yarn seed            # creates packs, cards, qa-admin, test customer
#      corepack yarn dev             # serves :9100
#
# 3. Mint the eligible product for the card-management spec:
#      corepack yarn medusa exec ./src/scripts/create-test-product.ts
#
# 4. Build/serve the storefront against :9100 and an admin vite against it, set
#    PW_BASE / PW_ADMIN / PW_BACKEND / PW_PK above to match, then run-e2e.ps1.
#    (Seed prints the publishable key; or read it from the store's API keys.)
