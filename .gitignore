# graphify — ignore ALL generated graph artifacts (cache/, manifest.json,
# graph.json ~3MB, graph.html, AND GRAPH_REPORT.md). The post-commit/post-checkout
# hooks rebuild them on every commit and they otherwise churn thousands of lines in
# every diff. They stay on disk locally (queries still work) and a fresh clone
# regenerates them via the hooks / `graphify .` — nothing under graphify-out/ is committed.
graphify-out/*

# git worktrees (superpowers using-git-worktrees skill)
/.worktrees/

# Playwright E2E artifacts
/tests/e2e/.auth/
/tests/e2e/.report/
/tests/e2e/.artifacts/
/playwright-report/
/test-results/
/tests/e2e/.env.e2e
/tests/prod-smoke/.artifacts/

# brainstorming visual-companion scratch
.superpowers/

# Local tool/build caches (regenerated locally, never committed)
.turbo/
.clone/

# ── Private — keep AI config, docs, tests & working notes LOCAL only ──
# Untracked via `git rm --cached`; files remain on disk. README.md + CHANGELOG.md stay public.
# AGENTS.md is the source-of-truth; the rest are generated by scripts/sync-agent-rules.sh.
AGENTS.md
CLAUDE.md
GEMINI.md
