# ─────────────────────────────────────────────────────────────────────────────
# Feature toggles (storefront)
#
# Each flag is OFF unless set to exactly "true". Leaving them unset/false ships
# the Packs-only deploy: the Marketplace and Pack Party sections are hidden — the
# nav tabs disappear (Pack Party becomes a non-clickable "Coming Soon" tab) and
# /marketplace + /pack-party return 404.
#
# To work on these features locally, copy this file to .env.local and set the
# relevant flag to "true". To re-enable in production later, set it in the deploy
# environment and rebuild — NEXT_PUBLIC_* vars are inlined at build time.
#
# See src/lib/features.ts.
NEXT_PUBLIC_FEATURE_MARKETPLACE=false
NEXT_PUBLIC_FEATURE_PACK_PARTY=false

# Copy this file to .env.local (gitignored) and fill in real values there. This
# template lists the storefront's public (NEXT_PUBLIC_*) env with safe
# placeholders — real secret values (a live publishable key, the Sentry auth
# token) are never committed here.

# Canonical public origin (no trailing slash) — used for metadataBase, the
# sitemap, and robots.txt. Set to the real domain in the deploy env.
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Sentry error monitoring. Leave DSN blank to disable reporting (Sentry no-ops).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source-map upload at build time (CI/deploy only; never commit).
SENTRY_AUTH_TOKEN=

# Medusa backend (see backend/) — the storefront 401s on every /store call
# without a valid publishable key (src/lib/medusa.ts has no fallback for it).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Obtain: seeded on first backend deploy (deploy:init prints it), or
# Admin dashboard → Settings → Publishable API keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_ME

# Optional CDN / object-storage hostname for uploaded media (S3 / Spaces). Unset
# = no external media host; when set it is allow-listed in the Content-Security-
# Policy (src/lib/security/csp.ts).
NEXT_PUBLIC_MEDIA_HOST=
